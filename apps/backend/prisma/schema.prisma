generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  DIRECTION
  ENSEIGNANT
  SURVEILLANT
  PARENT
  ELEVE
}

enum NotificationChannel {
  PUSH
  SMS
  BOTH
}

enum Checkpoint {
  PORTAIL
  CLASSE
}

enum AttendanceDirection {
  ENTREE
  SORTIE
}

// NOTE: `id` est l'identifiant partagé avec le mobile (WatermelonDB) — le
// protocole de sync matche les enregistrements par cet id dans les deux sens,
// donc aucune colonne `server_id` séparée n'est nécessaire (voir aussi
// apps/mobile/src/db/schema.ts).
model School {
  id                         String    @id @default(uuid())
  name                       String
  attendanceReferenceTime    String    @map("attendance_reference_time") // "HH:mm"
  attendanceToleranceMinutes Int       @map("attendance_tolerance_minutes")
  // Paire Ed25519 utilisée pour signer les cartes QR de cette école : la clé
  // privée ne quitte jamais le backend, la clé publique est synchronisée vers
  // les appareils pour une vérification de signature 100% hors-ligne.
  cardSigningPrivateKey      String    @map("card_signing_private_key")
  cardSigningPublicKey       String    @map("card_signing_public_key")
  // Coordonnées GPS des 4 coins du périmètre de l'école, dans l'ordre
  // (polygone simple) : [{ lat, lng }, ...]. `null` = pas encore configuré,
  // aucune restriction de position appliquée au pointage.
  geofenceCorners            Json?     @map("geofence_corners")
  // Plage horaire ("HH:mm") où le pointage est autorisé. `null` = pas de
  // restriction. Indépendant de attendanceReferenceTime, qui ne sert qu'à
  // détecter un retard — pas à bloquer le pointage.
  scanWindowStart            String?   @map("scan_window_start")
  scanWindowEnd              String?   @map("scan_window_end")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")
  deletedAt                  DateTime? @map("deleted_at")

  classes            SchoolClass[]
  students           Student[]
  users              User[]
  attendanceSessions AttendanceSession[]

  @@map("schools")
}

model SchoolClass {
  id        String    @id @default(uuid())
  schoolId  String    @map("school_id")
  name      String
  promotion String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school             School              @relation(fields: [schoolId], references: [id])
  students           Student[]
  assignedTeachers   User[]              @relation("class_assignments")
  attendanceSessions AttendanceSession[]

  @@index([schoolId])
  @@map("school_classes")
}

model Student {
  id            String    @id @default(uuid())
  schoolId      String    @map("school_id")
  schoolClassId String    @map("school_class_id")
  lastName      String    @map("last_name")
  middleName    String?   @map("middle_name")
  firstName     String    @map("first_name")
  sex           String
  dateOfBirth   String    @map("date_of_birth")
  photoUrl      String?   @map("photo_url")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  school      School             @relation(fields: [schoolId], references: [id])
  schoolClass SchoolClass        @relation(fields: [schoolClassId], references: [id])
  parents     ParentGuardian[]
  cards       StudentCard[]
  attendances AttendanceRecord[]
  absences    Absence[]
  // Compte de connexion ELEVE de cet élève, s'il a été provisionné.
  account     User?
  // Comptes PARENT autorisés à voir/modifier la fiche de cet élève — un
  // même parent peut être lié à plusieurs enfants (fratrie), d'où une
  // relation many-to-many plutôt qu'un simple studentId sur User comme pour
  // ELEVE.
  parentUsers User[]             @relation("parent_of")

  @@index([schoolId])
  @@index([schoolClassId])
  @@map("students")
}

model ParentGuardian {
  id                   String              @id @default(uuid())
  studentId            String              @map("student_id")
  fullName             String              @map("full_name")
  relationship         String
  phoneNumber          String              @map("phone_number")
  secondaryPhoneNumber String?             @map("secondary_phone_number")
  address              String?
  notificationChannel  NotificationChannel @default(BOTH) @map("notification_channel")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("parent_guardians")
}

// Un élève sans aucun pointage PORTAIL avant l'heure de référence + tolérance
// de son école est marqué absent automatiquement (cf. AbsenceDetectionJob).
// Le parent peut ensuite justifier l'absence a posteriori (3.5 du cahier des
// charges).
model Absence {
  id                   String    @id @default(uuid())
  studentId             String    @map("student_id")
  date                  String // "YYYY-MM-DD"
  justified             Boolean   @default(false)
  justificationReason   String?   @map("justification_reason")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
  @@index([studentId])
  @@map("absences")
}

model StudentCard {
  id        String   @id // == cardId encodé dans le QR
  studentId String   @map("student_id")
  signature String // signature Ed25519 en base64
  issuedAt  DateTime @map("issued_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("student_cards")
}

model AttendanceRecord {
  id         String              @id // généré côté mobile (WatermelonDB), réutilisé tel quel
  studentId  String              @map("student_id")
  checkpoint Checkpoint
  direction  AttendanceDirection
  recordedAt DateTime            @map("recorded_at")
  isLate     Boolean             @map("is_late")
  receivedAt DateTime            @default(now()) @map("received_at")
  // Non-null uniquement pour un pointage auto-scanné par l'élève via le QR
  // de session (cf. AttendanceSession) — null pour un scan de carte classique.
  sessionId  String?             @map("session_id")
  // Position GPS captée sur l'appareil au moment du scan — renseignée
  // uniquement si l'école a un périmètre configuré (voir School.geofenceCorners).
  // Conservée à titre d'audit ; la validation elle-même a déjà eu lieu côté
  // appareil avant la création de ce pointage, et est revérifiée ici en
  // défense en profondeur (voir AttendanceService.recordFromSync).
  latitude   Float?
  longitude  Float?

  student Student            @relation(fields: [studentId], references: [id])
  session AttendanceSession? @relation(fields: [sessionId], references: [id])

  // Un élève ne peut pointer qu'une fois par session (des sessionId null ne
  // se contraignent pas entre eux sous Postgres, donc les scans de carte
  // classiques, où sessionId est toujours null, ne sont pas concernés).
  @@unique([sessionId, studentId])
  @@index([studentId])
  @@index([recordedAt])
  @@map("attendance_records")
}

// Session de présence ouverte par un enseignant pour sa classe du moment :
// le QR affiché encode ce payload signé par la clé de l'appareil enseignant
// (voir TeacherSigningKey) et est scanné par l'élève sur son propre appareil,
// à l'inverse du flux carte (enseignant scanne l'élève).
model AttendanceSession {
  id            String    @id // généré côté mobile (WatermelonDB), réutilisé tel quel
  schoolId      String    @map("school_id")
  schoolClassId String    @map("school_class_id")
  teacherId     String    @map("teacher_id")
  openedAt      DateTime  @map("opened_at")
  expiresAt     DateTime  @map("expires_at")
  closedAt      DateTime? @map("closed_at")
  receivedAt    DateTime  @default(now()) @map("received_at")

  school      School             @relation(fields: [schoolId], references: [id])
  schoolClass SchoolClass        @relation(fields: [schoolClassId], references: [id])
  teacher     User               @relation(fields: [teacherId], references: [id])
  records     AttendanceRecord[]

  @@index([schoolId])
  @@index([schoolClassId])
  @@map("attendance_sessions")
}

// Clé publique Ed25519 générée par l'appareil enseignant lui-même (la privée
// ne quitte jamais l'appareil, symétrique à School.cardSigningPrivateKey qui
// ne quitte jamais le backend). Permet aux appareils élèves de vérifier hors
// ligne la signature d'un QR de session, une fois cette clé synchronisée.
model TeacherSigningKey {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  publicKey String   @map("public_key") // hex Ed25519
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("teacher_signing_keys")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole
  schoolId     String?  @map("school_id")
  // Renseigné uniquement pour un compte ELEVE : relie le compte de connexion
  // à sa fiche élève.
  studentId    String?  @unique @map("student_id")
  // Jeton Expo Push (device), renseigné dès l'app ouverte et connectée —
  // permet l'envoi de notifications push (arrivée, absence).
  expoPushToken String? @map("expo_push_token")
  // Désactivation soft d'un compte staff (ENSEIGNANT/SURVEILLANT) par la
  // Direction — rejeté par JwtAuthGuard dès la prochaine requête, pas
  // seulement au prochain login.
  disabledAt    DateTime? @map("disabled_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  school          School?             @relation(fields: [schoolId], references: [id])
  student         Student?            @relation(fields: [studentId], references: [id])
  assignedClasses SchoolClass[]       @relation("class_assignments")
  openedSessions  AttendanceSession[]
  signingKey      TeacherSigningKey?
  // Renseigné uniquement pour un compte PARENT : les enfants que ce compte
  // est autorisé à consulter/modifier.
  children        Student[]           @relation("parent_of")

  @@map("users")
}
