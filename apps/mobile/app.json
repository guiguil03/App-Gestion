{
  "expo": {
    "name": "Presence Scolaire",
    "slug": "project-presence",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "presencescolaire",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.presenceSchool.app",
      "infoPlist": {
        "NSCameraUsageDescription": "La caméra est utilisée pour scanner le QR code de la carte d'élève lors du pointage.",
        "NSLocationWhenInUseUsageDescription": "La position est utilisée pour vérifier que le pointage a bien lieu dans le périmètre de l'école.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E7F5EF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "package": "com.presenceSchool.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "La caméra est utilisée pour scanner le QR code de la carte d'élève lors du pointage."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "La position est utilisée pour vérifier que le pointage a bien lieu dans le périmètre de l'école."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#059669",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a54b2601-0658-47b1-895f-1282b2b2f5ee"
      }
    },
    "owner": "glafay996"
  }
}
